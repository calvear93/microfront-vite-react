{
	"project": "(((project-name)))",
	"description": "(((project-description)))",
	"scripts": {
        "dev": "pnpm run \"/apps:.*\"/ preview",
		"apps:container": "env -m debug @apps/container : pnpm --filter [[m.1]]",
		"apps:home": "env -m debug @apps/home : pnpm --filter [[m.1]]",
		"test": "vitest --run",
		"format": "prettier --write **/*.{ts,tsx,css,scss,sass,json,html,md,yml,yaml}",
		"lint": "eslint src/**/*.{ts,tsx}",
		"syncpack": "syncpack fix-mismatches -i \"\t\" && syncpack format -i \"\t\"",
		"clean": "pnpx del-cli **/node_modules **/dist **/.rollup.cache **/.reports **/*.tsbuildinfo **/debug.log"
	},
